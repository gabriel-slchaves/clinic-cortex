{
  "name": "cliniccortex",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host --mode local",
    "build": "vite build --mode production",
    "build:homolog": "vite build --mode homolog",
    "build:production": "vite build --mode production",
    "preview": "vite preview --host",
    "check": "tsc --noEmit",
    "check:whatsapp": "tsc -p whatsapp-service/tsconfig.json --noEmit",
    "format": "prettier --write .",
    "stack:local": "docker compose --env-file .env.local -f docker-compose.yml up -d --build",
    "stack:homolog": "docker compose --env-file .env.homolog -f docker-compose.homolog.yml up -d --build",
    "stack:production": "docker compose --env-file .env.production -f docker-compose.production.yml up -d --build",
    "whatsapp:dev": "node --env-file=.env.local --watch --import tsx whatsapp-service/src/index.ts",
    "whatsapp:build": "tsc -p whatsapp-service/tsconfig.json",
    "whatsapp:start": "node whatsapp-service/dist/index.js",
    "whatsapp:start:local": "node --env-file=.env.local whatsapp-service/dist/index.js",
    "whatsapp:start:homolog": "node --env-file=.env.homolog whatsapp-service/dist/index.js",
    "whatsapp:start:production": "node --env-file=.env.production whatsapp-service/dist/index.js",
    "whatsapp:preflight:local": "node --env-file=.env.local --import tsx whatsapp-service/src/scripts/metaPreflight.ts --expect-env=local --check-http --http-origin=http://127.0.0.1:3001",
    "whatsapp:preflight:homolog": "node --env-file=.env.homolog --import tsx whatsapp-service/src/scripts/metaPreflight.ts --expect-env=homolog",
    "whatsapp:probe:homolog": "node --env-file=.env.homolog --import tsx whatsapp-service/src/scripts/metaPreflight.ts --expect-env=homolog --check-http",
    "whatsapp:preflight:production": "node --env-file=.env.production --import tsx whatsapp-service/src/scripts/metaPreflight.ts --expect-env=production",
    "whatsapp:probe:production": "node --env-file=.env.production --import tsx whatsapp-service/src/scripts/metaPreflight.ts --expect-env=production --check-http",
    "whatsapp:generate-encryption-key": "node --input-type=module -e \"import { randomBytes } from 'node:crypto'; console.log(randomBytes(32).toString('base64'));\"",
    "whatsapp:generate-verify-token": "node --input-type=module -e \"import { randomBytes } from 'node:crypto'; console.log(randomBytes(32).toString('hex'));\""
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.99.1",
    "@tanstack/react-query": "^5.96.2",
    "@types/three": "^0.183.1",
    "axios": "^1.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.22",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.453.0",
    "nanoid": "^5.1.5",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "react": "^19.2.1",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.64.0",
    "react-resizable-panels": "^3.0.6",
    "recharts": "^2.15.2",
    "sonner": "^2.0.7",
    "streamdown": "^1.4.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.2",
    "vaul": "^1.1.2",
    "wouter": "^3.3.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@builder.io/vite-plugin-jsx-loc": "^0.1.1",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.3",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "add": "^2.0.6",
    "autoprefixer": "^10.4.20",
    "pnpm": "^10.15.1",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.6.3",
    "vite": "^7.1.7",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af",
  "pnpm": {
    "overrides": {
      "tailwindcss>nanoid": "3.3.7"
    }
  }
