# Copy to n8n.env before production deploy.
N8N_HOST=n8n
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=https://wa.cliniccortex.com.br/
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me
META_APP_ID=replace_me
META_APP_SECRET=replace_me
META_GRAPH_VERSION=v23.0
META_EMBEDDED_SIGNUP_CONFIG_ID=replace_me
META_EMBEDDED_SIGNUP_REDIRECT_URI=https://app.cliniccortex.com.br/integrations/whatsapp/meta/callback
META_EMBEDDED_SIGNUP_SCOPES=business_management,whatsapp_business_management,whatsapp_business_messaging
META_WEBHOOK_VERIFY_TOKEN=replace_me
META_WEBHOOK_APP_SECRET=replace_me
WHATSAPP_TOKEN_ENCRYPTION_KEY=replace_me
TEAM_SERVICE_INTERNAL_URL=http://team-service:3002
NODE_FUNCTION_ALLOW_BUILTIN=crypto,node:crypto
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo
